# Plantilla del .env de producción. En el VPS: /var/apps/decoraciones/.env (permisos 600, dueño root).
# NUNCA se versiona con valores reales (el .gitignore excluye .env). Copiar y rellenar en el host.

# Cadena de conexión a SQL Server compartido (usuario dedicado, NO sa).
# Host = alias de red del contenedor SQL. La BD y el login los crea el agente del VPS.
ConnectionStrings__DefaultConnection=Server=trajano-sqlserver,1433;Database=DecoracionesDB;User Id=decoraciones_app;Password=CAMBIAR_CANAL_SEGURO;TrustServerCertificate=True;MultipleActiveResultSets=true

# Admin inicial de la app. El seed lo crea SOLO si no existe todavía (idempotente).
# Ojo: doble guion bajo (__) mapea a la sección SeedSettings de la config .NET.
SeedSettings__AdminEmail=CAMBIAR_CANAL_SEGURO
SeedSettings__AdminPassword=CAMBIAR_CANAL_SEGURO
SeedSettings__AdminFullName=Administrador
