@model IReadOnlyList<Decorations.Application.DTOs.ContactMessageDto>
@{ ViewData["Title"] = "Mensajes de contacto"; }

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Mensajes de contacto</h1>
    <span class="text-sm text-gray-500 dark:text-gray-400">@Model.Count(m => !m.IsRead) sin leer</span>
</div>

@if (!Model.Any())
{
    <div class="card p-12 text-center">
        <p class="text-gray-500 dark:text-gray-400">No hay mensajes aún.</p>
    </div>
}
else
{
    <div class="space-y-4">
        @foreach (var message in Model)
        {
            <div class="card p-6 @(!message.IsRead ? "border-l-4 border-primary-500" : "")">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-1">
                            <span class="font-semibold text-gray-900 dark:text-white">@message.Name</span>
                            @if (!message.IsRead)
                            {
                                <span class="px-2 py-0.5 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400 rounded-full text-xs font-semibold">Nuevo</span>
                            }
                        </div>
                        <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">
                            <a href="mailto:@message.Email" class="hover:text-primary-600 transition-colors">@message.Email</a>
                            @if (!string.IsNullOrEmpty(message.Phone)) { <span> · @message.Phone</span> }
                            @if (!string.IsNullOrEmpty(message.EventType)) { <span> · @message.EventType</span> }
                            <span> · @message.ReceivedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <p class="text-gray-700 dark:text-gray-300">@message.Message</p>
                    </div>
                    <div class="flex gap-2 flex-shrink-0">
                        @if (!message.IsRead)
                        {
                            <form asp-area="Admin" asp-controller="ContactSettings" asp-action="MarkAsRead" asp-route-id="@message.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-xs px-3 py-1.5 bg-green-100 dark:bg-green-900/20 text-green-700 dark:text-green-400 rounded-lg hover:bg-green-200 transition-colors">✓ Marcar leído</button>
                            </form>
                        }
                        <form asp-area="Admin" asp-controller="ContactSettings" asp-action="DeleteMessage" asp-route-id="@message.Id" method="post"
                              onsubmit="return confirm('¿Eliminar este mensaje?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-xs px-3 py-1.5 bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-200 transition-colors">Eliminar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
