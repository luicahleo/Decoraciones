<!DOCTYPE html>
<html lang="es"
      x-data="{ darkMode: localStorage.getItem('theme') === 'dark', sidebarOpen: true }"
      :class="{ 'dark': darkMode }"
      x-init="$watch('darkMode', val => localStorage.setItem('theme', val ? 'dark' : 'light'))">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="bg-gray-100 dark:bg-gray-950 font-sans min-h-screen">

    <div class="flex h-screen overflow-hidden">
        <aside class="bg-gray-900 dark:bg-gray-950 text-white w-64 flex-shrink-0 flex flex-col"
               x-show="sidebarOpen">
            <div class="p-6 border-b border-gray-700">
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="text-lg font-bold text-primary-400">✨ Decoraciones</a>
                <p class="text-xs text-gray-500 mt-1">Panel de administración</p>
            </div>
            <nav class="flex-1 p-4 space-y-1">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-300 hover:bg-gray-800 hover:text-white transition-colors duration-200">
                    📊 Dashboard
                </a>
                <a asp-area="Admin" asp-controller="GalleryManagement" asp-action="Index"
                   class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-300 hover:bg-gray-800 hover:text-white transition-colors duration-200">
                    🖼️ Galería
                </a>
                <a asp-area="Admin" asp-controller="ServiceManagement" asp-action="Index"
                   class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-300 hover:bg-gray-800 hover:text-white transition-colors duration-200">
                    🎯 Servicios
                </a>
                <a asp-area="Admin" asp-controller="ContactSettings" asp-action="Index"
                   class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-300 hover:bg-gray-800 hover:text-white transition-colors duration-200">
                    ⚙️ Configuración
                </a>
                <a asp-area="Admin" asp-controller="ContactSettings" asp-action="Messages"
                   class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-300 hover:bg-gray-800 hover:text-white transition-colors duration-200">
                    💬 Mensajes
                </a>
            </nav>
            <div class="p-4 border-t border-gray-700">
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-gray-800 hover:text-white transition-colors duration-200 text-left">
                        🚪 Cerrar sesión
                    </button>
                </form>
            </div>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden">
            <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between">
                <button @@click="sidebarOpen = !sidebarOpen"
                        class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-gray-600 dark:text-gray-400">@User.Identity?.Name</span>
                    <button @@click="darkMode = !darkMode"
                            class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                        <svg x-show="!darkMode" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
                        <svg x-show="darkMode" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                    </button>
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-6 bg-gray-50 dark:bg-gray-950">
                @if (TempData["Success"] != null)
                {
                    <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl text-green-700 dark:text-green-400">
                        ✅ @TempData["Success"]
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
