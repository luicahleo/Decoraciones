@model Decorations.Web.ViewModels.Admin.GalleryManagementViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="card p-6 text-center">
        <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">@Model.GalleryItems.Count</div>
        <div class="text-gray-600 dark:text-gray-400 mt-1">Elementos en Galería</div>
    </div>
    <div class="card p-6 text-center">
        <div class="text-3xl font-bold text-green-600 dark:text-green-400">@Model.GalleryItems.Count(g => g.IsActive)</div>
        <div class="text-gray-600 dark:text-gray-400 mt-1">Elementos Activos</div>
    </div>
    <div class="card p-6 text-center">
        <div class="text-3xl font-bold text-orange-600 dark:text-orange-400">@Model.UnreadMessagesCount</div>
        <div class="text-gray-600 dark:text-gray-400 mt-1">Mensajes sin leer</div>
    </div>
</div>

<div class="card p-6">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Accesos rápidos</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a asp-area="Admin" asp-controller="GalleryManagement" asp-action="Create"
           class="flex items-center gap-4 p-4 bg-primary-50 dark:bg-primary-900/20 rounded-xl hover:bg-primary-100 dark:hover:bg-primary-900/40 transition-colors">
            <span class="text-2xl">🖼️</span>
            <div>
                <div class="font-semibold text-gray-900 dark:text-white">Añadir a Galería</div>
                <div class="text-sm text-gray-500 dark:text-gray-400">Subir nuevas fotos o vídeos</div>
            </div>
        </a>
        <a asp-area="Admin" asp-controller="ContactSettings" asp-action="Messages"
           class="flex items-center gap-4 p-4 bg-orange-50 dark:bg-orange-900/20 rounded-xl hover:bg-orange-100 dark:hover:bg-orange-900/40 transition-colors">
            <span class="text-2xl">💬</span>
            <div>
                <div class="font-semibold text-gray-900 dark:text-white">Ver Mensajes</div>
                <div class="text-sm text-gray-500 dark:text-gray-400">@Model.UnreadMessagesCount sin leer</div>
            </div>
        </a>
    </div>
</div>
