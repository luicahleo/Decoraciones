@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}
<section class="py-24 px-4 bg-white dark:bg-gray-950 text-center">
    <div class="max-w-lg mx-auto">
        <div class="text-6xl mb-6">⚠️</div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Ha ocurrido un error</h1>
        <p class="text-gray-600 dark:text-gray-400 text-lg mb-8">Lo sentimos, algo fue mal. Por favor, intenta de nuevo más tarde.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-primary inline-block">Volver al inicio</a>
    </div>
</section>
