@model Decorations.Web.ViewModels.GalleryViewModel

<!-- Page hero -->
<section class="relative pt-36 pb-16 px-4"
         style="background-image: url('https://images.pexels.com/photos/17023030/pexels-photo-17023030.jpeg?auto=compress&cs=tinysrgb&w=1920&q=60'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-primary-950/80"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
        <span class="section-eyebrow text-gold-300">Portfolio</span>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">Nuestra Galería</h1>
        <div class="w-12 h-0.5 bg-gold-400 mx-auto mb-5"></div>
        <p class="text-white/70 text-lg leading-relaxed">
            Inspírate con nuestros trabajos. Cada evento es único y especial.
        </p>
    </div>
</section>

<!-- Gallery grid -->
<section class="py-20 px-4 bg-white dark:bg-gray-950"
         x-data="{ lightbox: false, currentImage: '', currentAlt: '' }">
    <div class="max-w-7xl mx-auto">

        @if (!Model.GalleryItems.Any())
        {
            <div class="text-center py-24">
                <div class="w-20 h-20 bg-primary-50 dark:bg-primary-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6">
                    <span class="text-4xl">✿</span>
                </div>
                <p class="font-display text-2xl text-gray-400 dark:text-gray-500 mb-2">Próximamente</p>
                <p class="text-gray-400 text-sm">Nuevas decoraciones estarán disponibles muy pronto.</p>
                <div class="mt-8">
                    <a asp-controller="Contact" asp-action="Index" class="btn-primary inline-block">Contáctanos</a>
                </div>
            </div>
        }
        else
        {
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
                @foreach (var item in Model.GalleryItems)
                {
                    @foreach (var media in item.MediaAssets)
                    {
                        if (media.MediaType == Decorations.Domain.Enums.MediaType.Image)
                        {
                            <div class="break-inside-avoid overflow-hidden rounded-2xl cursor-pointer group relative shadow-sm hover:shadow-xl transition-shadow duration-300"
                                 @@click="lightbox = true; currentImage = '@media.FullSizePath'; currentAlt = '@Html.Raw(media.AltText.Replace("'", "\\'"))'">
                                <img src="@media.ThumbnailPath"
                                     alt="@media.AltText"
                                     loading="lazy"
                                     class="w-full object-cover group-hover:scale-105 transition-transform duration-700" />
                                <!-- Hover overlay -->
                                <div class="absolute inset-0 bg-gradient-to-t from-primary-900/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
                                    <div>
                                        <p class="text-white font-display font-semibold text-sm">@item.Title</p>
                                        <p class="text-white/60 text-xs mt-1">Ver imagen</p>
                                    </div>
                                </div>
                                <!-- Zoom icon -->
                                <div class="absolute top-3 right-3 w-8 h-8 bg-white/90 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-md">
                                    <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                                    </svg>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="break-inside-avoid rounded-2xl overflow-hidden aspect-video shadow-sm">
                                <iframe src="https://www.youtube.com/embed/@media.YoutubeVideoId"
                                        title="@media.AltText"
                                        class="w-full h-full"
                                        loading="lazy"
                                        allowfullscreen></iframe>
                            </div>
                        }
                    }
                }
            </div>
        }
    </div>

    <!-- Lightbox -->
    <div x-show="lightbox"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4"
         @@click.self="lightbox = false"
         @@keydown.escape.window="lightbox = false">
        <div class="relative max-w-5xl max-h-[90vh]">
            <img :src="currentImage" :alt="currentAlt"
                 class="max-w-full max-h-[85vh] rounded-2xl object-contain shadow-2xl" />
            <button @@click="lightbox = false"
                    class="absolute -top-4 -right-4 bg-white text-gray-900 rounded-full w-10 h-10 flex items-center justify-center hover:bg-gray-100 transition-colors shadow-lg font-bold text-sm">
                ✕
            </button>
        </div>
    </div>
</section>

<!-- CTA at bottom -->
<section class="py-16 px-4 bg-cream-50 dark:bg-gray-900 border-t border-cream-200 dark:border-gray-800">
    <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-gray-900 dark:text-white mb-4">¿Te gustó lo que viste?</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">
            Podemos crear algo igual de especial para tu evento. Contáctanos y hablemos de tus ideas.
        </p>
        <a asp-controller="Contact" asp-action="Index" class="btn-primary inline-block">Solicitar Presupuesto</a>
    </div>
</section>
