@model Decorations.Web.ViewModels.HomeViewModel

<!-- ═══════════════════════════════════════════════════
     HERO — Full-screen image with overlay
════════════════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden"
         style="background-image: url('https://images.pexels.com/photos/16120206/pexels-photo-16120206.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80'); background-size: cover; background-position: center;">

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <span class="inline-block text-gold-300 text-sm font-semibold uppercase tracking-[0.3em] mb-6">
            ✦ &nbsp; Decoración de Eventos &nbsp; ✦
        </span>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
            Creamos momentos<br>
            <em class="not-italic text-primary-300">inolvidables</em>
        </h1>
        <p class="text-lg md:text-xl text-white/75 mb-10 max-w-2xl mx-auto leading-relaxed">
            Decoraciones únicas y personalizadas para tus eventos más especiales.
            Bodas, cumpleaños, bautizos y mucho más.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Contact" asp-action="Index" class="btn-white inline-block">
                Solicitar Presupuesto
            </a>
            <a asp-controller="Gallery" asp-action="Index"
               class="inline-block border-2 border-white/60 text-white/90 hover:border-white hover:text-white font-semibold py-3 px-8 rounded-full transition-all duration-300 tracking-wide">
                Ver Galería
            </a>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 animate-bounce">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
        </svg>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     STATS BAR
════════════════════════════════════════════════════ -->
<section class="bg-white dark:bg-gray-900 border-b border-cream-200 dark:border-gray-800 py-12">
    <div class="max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <p class="stat-number">200<span class="text-primary-400">+</span></p>
                <p class="stat-label">Eventos Realizados</p>
            </div>
            <div>
                <p class="stat-number">5<span class="text-primary-400">★</span></p>
                <p class="stat-label">Valoración Clientes</p>
            </div>
            <div>
                <p class="stat-number">8<span class="text-primary-400">+</span></p>
                <p class="stat-label">Años de Experiencia</p>
            </div>
            <div>
                <p class="stat-number">100<span class="text-primary-400">%</span></p>
                <p class="stat-label">Satisfacción</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     SERVICES
════════════════════════════════════════════════════ -->
@if (Model.Services.Any())
{
    <section class="py-24 px-4 bg-cream-50 dark:bg-gray-950">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="section-eyebrow">Lo que hacemos</span>
                <h2 class="section-title">Nuestros Servicios</h2>
                <div class="gold-divider"></div>
                <p class="section-subtitle">Ofrecemos una amplia variedad de servicios de decoración para hacer de tu evento algo único e irrepetible.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var service in Model.Services)
                {
                    <div class="card p-8 text-center group hover:-translate-y-1 transition-transform duration-300">
                        @if (!string.IsNullOrEmpty(service.IconCssClass))
                        {
                            <div class="w-16 h-16 bg-primary-50 dark:bg-primary-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-primary-100 transition-colors duration-300">
                                <span class="text-3xl">@service.IconCssClass</span>
                            </div>
                        }
                        else
                        {
                            <div class="w-16 h-16 bg-primary-50 dark:bg-primary-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6">
                                <span class="text-3xl">✿</span>
                            </div>
                        }
                        <h3 class="font-display text-xl font-bold text-gray-900 dark:text-white mb-3">@service.Title</h3>
                        <div class="w-8 h-0.5 bg-gold-400 mx-auto mb-4"></div>
                        <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">@service.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ═══════════════════════════════════════════════════
     GALLERY PREVIEW
════════════════════════════════════════════════════ -->
@if (Model.GalleryPreview.Any())
{
    <section class="py-24 px-4 bg-white dark:bg-gray-900">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <span class="section-eyebrow">Portfolio</span>
                <h2 class="section-title">Nuestros Trabajos</h2>
                <div class="gold-divider"></div>
                <p class="section-subtitle">Una muestra de las decoraciones que hemos creado con amor para nuestros clientes.</p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-12">
                @foreach (var item in Model.GalleryPreview)
                {
                    var images = item.MediaAssets
                        .Where(m => m.MediaType == Decorations.Domain.Enums.MediaType.Image)
                        .OrderBy(m => m.DisplayOrder)
                        .ToList();

                    if (!images.Any())
                    {
                        continue;
                    }

                    if (item.ShowAsGrid)
                    {
                        // Tipo grid: mosaico con las primeras 4 imágenes (sin portada destacada).
                        var mosaic = images.Take(4).ToList();
                        var extra = images.Count - mosaic.Count;
                        // Layout según cuántas imágenes haya, manteniendo la celda cuadrada.
                        var mosaicClass = mosaic.Count >= 4 ? "grid-cols-2 grid-rows-2"
                            : mosaic.Count == 3 ? "grid-cols-2 grid-rows-2"
                            : mosaic.Count == 2 ? "grid-cols-2 grid-rows-1"
                            : "grid-cols-1 grid-rows-1";

                        <a asp-controller="Gallery" asp-action="Details" asp-route-id="@item.Id"
                           class="block overflow-hidden rounded-2xl aspect-square group cursor-pointer relative">
                            <div class="w-full h-full grid gap-0.5 @mosaicClass">
                                @for (int i = 0; i < mosaic.Count; i++)
                                {
                                    var img = mosaic[i];
                                    // Con 3 imágenes la primera ocupa la columna izquierda completa.
                                    var spanClass = mosaic.Count == 3 && i == 0 ? "row-span-2" : string.Empty;
                                    <div class="relative overflow-hidden @spanClass">
                                        <img src="@img.ThumbnailPath"
                                             alt="@img.AltText"
                                             loading="lazy"
                                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                                        @if (i == mosaic.Count - 1 && extra > 0)
                                        {
                                            <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
                                                <span class="text-white text-2xl font-semibold">+@extra</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 pointer-events-none">
                                <span class="text-white text-sm font-medium">@item.Title</span>
                            </div>
                        </a>
                    }
                    else
                    {
                        // Tipo portada: prioriza la imagen destacada (IsFeatured); si ninguna, la de menor orden.
                        var coverImage = images
                            .OrderByDescending(m => m.IsFeatured)
                            .ThenBy(m => m.DisplayOrder)
                            .First();

                        <a asp-controller="Gallery" asp-action="Details" asp-route-id="@item.Id"
                           class="block overflow-hidden rounded-2xl aspect-square group cursor-pointer relative">
                            <img src="@coverImage.ThumbnailPath"
                                 alt="@coverImage.AltText"
                                 loading="lazy"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 pointer-events-none">
                                <span class="text-white text-sm font-medium">@item.Title</span>
                            </div>
                        </a>
                    }
                }
            </div>

            <div class="text-center">
                <a asp-controller="Gallery" asp-action="Index" class="btn-primary inline-block">Ver Galería Completa</a>
            </div>
        </div>
    </section>
}

<!-- ═══════════════════════════════════════════════════
