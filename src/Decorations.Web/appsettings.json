{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=DecorationsDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "JWT": {
    "SecretKey": "DECORATIONS-JWT-SECRET-KEY-2024-SUPER-SECURE-KEY-MINIMUM-32-CHARACTERS",
    "Issuer": "Decorations.API",
    "Audience": "Decorations.Clients",
    "ExpirationMinutes": "60"
  },
  "ImageProcessing": {
    "MaxWidthPixels": 1200,
    "MaxHeightPixels": 1200,
    "MaxFileSizeBytes": 5242880,
    "WebPQuality": 80
  },
  "ApiSettings": {
    "BaseUrl": "http://localhost:5090",
    "PublicUrl": "http://localhost:5090"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {MachineName} {ThreadId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
